{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 1,

  "modules-left": ["niri/workspaces", "niri/window"],
  "modules-center": ["clock"],
  "modules-right": [
    "tray",
    "cpu",
    "memory",
    "group/audio",
    "bluetooth",
    "network",
    "battery",
  ],

  "niri/window": {
    "icon": true,
    "icon-size": 20,
    "max-length": 30,
  },

  "clock": {
    "format": "{:%I:%M %p â€¢ %A, %B %d}",
  },

  "tray": {
    "spacing": 8,
  },
  "cpu": {
    "interval": 2,
    "format": "ï‹› {usage}%",
    "on-click": "kitty -e btop",
  },
  "memory": {
    "interval": 2,
    "format": "î؟… {percentage}%",
    "on-click": "kitty -e btop",
  },
  "group/audio": {
    "orientation": "horizontal",
    "modules": ["pulseaudio", "pulseaudio/slider"],
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"],
    },
    "format-muted": "َ°–پ",
    "on-click": "pavucontrol",
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "horizontal",
  },
  "bluetooth": {
    "format": "ïٹ”",
    "format-disabled": "َ°‚²",
    "format-connected": "ïٹ” {num_connections}",
    "on-click": "kitty -e bluetui",
  },
  "network": {
    "format-wifi": "{icon}",
    "format-ethernet": "î½„",
    "format-linked": "َ°ˆپ",
    "format-disconnected": "َ°¤­",
    "format-disabled": "َ°¤®",
    "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
    "tooltip-format-wifi": "{essid}",
    "tooltip-format-ethernet": "{ifname}",
    "tooltip-format-disconnected": "disconnected",
    "on-click": "kitty -e nmtui",
  },
  "battery": {
    "format": "{icon} {capacity}%",
    "states": {
      "warning": 30,
      "critical": 10,
    },
    "format-icons": {
      "default": ["ï‰„", "ï‰ƒ", "ï‰‚", "ï‰پ", "ï‰€"],
      "charging": "ï‡¦",
    },
  },
}
